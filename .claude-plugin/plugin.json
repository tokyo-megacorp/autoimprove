{
  "name": "autoimprove",
  "version": "0.5.0",
  "description": "Autonomous codebase improvement loop — modify code, evaluate against benchmarks, keep or discard via git worktrees",
  "author": {
    "name": "Pedro Almeida",
    "url": "https://github.com/ipedro"
  },
  "repository": "https://github.com/ipedro/autoimprove",
  "license": "MIT",
  "keywords": ["autoimprove", "autonomous", "improvement", "benchmarks", "experiments"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/skill-sentinel \"$TOOL_INPUT\""
          }
        ]
      }
    ]
  }
}
