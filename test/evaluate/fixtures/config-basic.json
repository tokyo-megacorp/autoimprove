{
  "gates": [
    { "name": "always-pass", "command": "true" }
  ],
  "benchmarks": [
    {
      "name": "mock-bench",
      "command": "bash FIXTURES_DIR/mock-benchmark.sh",
      "metrics": [
        {
          "name": "score",
          "extract": "json:.score",
          "direction": "higher_is_better",
          "tolerance": 0.02,
          "significance": 0.01
        },
        {
          "name": "speed_ms",
          "extract": "json:.speed_ms",
          "direction": "lower_is_better",
          "tolerance": 0.05,
          "significance": 0.02
        }
      ]
    }
  ],
  "regression_tolerance": 0.02,
  "significance_threshold": 0.01
}
